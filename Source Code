#include <stdio.h>
#include <stdlib.h>
#include <string.h>

#define MAX_STUDENTS 100
#define MAX_COURSES 10
#define NAME 50

typedef struct{
char id[20];
char name[NAME];
float marks[MAX_COURSES];
float total;
float avg;
float gpa;
char grade[5];
char result[10];
}Student;

int seq=1;
char courseNames[MAX_COURSES][NAME];

void generateID(char id[]){
sprintf(id,"251-15-%03d",seq++);
}

void assignGrade(Student *s,int courses){

int fail=0;

for(int i=0;i<courses;i++)
if(s->marks[i]<40)
fail=1;

if(fail){
s->gpa=0.00;
strcpy(s->grade,"F");
strcpy(s->result,"FAIL");
return;
}

strcpy(s->result,"PASS");

if(s->avg>=80){s->gpa=4.00; strcpy(s->grade,"A+");}
else if(s->avg>=75){s->gpa=3.75; strcpy(s->grade,"A");}
else if(s->avg>=70){s->gpa=3.50; strcpy(s->grade,"A-");}
else if(s->avg>=65){s->gpa=3.25; strcpy(s->grade,"B+");}
else if(s->avg>=60){s->gpa=3.00; strcpy(s->grade,"B");}
else if(s->avg>=55){s->gpa=2.75; strcpy(s->grade,"B-");}
else if(s->avg>=50){s->gpa=2.50; strcpy(s->grade,"C+");}
else if(s->avg>=45){s->gpa=2.25; strcpy(s->grade,"C");}
else if(s->avg>=40){s->gpa=2.00; strcpy(s->grade,"D");}
else{s->gpa=0.00; strcpy(s->grade,"F");}
}

void calculate(Student s[],int n,int c){

for(int i=0;i<n;i++){

s[i].total=0;

for(int j=0;j<c;j++)
s[i].total+=s[i].marks[j];

s[i].avg=s[i].total/c;

assignGrade(&s[i],c);
}
}

void inputCourses(int c){

printf("\nEnter Course Names\n");

for(int i=0;i<c;i++){
printf("Course %d: ",i+1);
scanf(" %[^\n]",courseNames[i]);
}
}

void inputStudents(Student s[],int n,int c){

for(int i=0;i<n;i++){

generateID(s[i].id);

printf("\nStudent %d\n",i+1);

printf("Name: ");
scanf(" %[^\n]",s[i].name);

for(int j=0;j<c;j++){
printf("%s: ",courseNames[j]);
scanf("%f",&s[i].marks[j]);
}
}
}

void merge(Student s[],int l,int m,int r){

Student temp[100];

int i=l,j=m+1,k=0;

while(i<=m && j<=r){

if(s[i].gpa>s[j].gpa)
temp[k++]=s[i++];
else
temp[k++]=s[j++];
}

while(i<=m) temp[k++]=s[i++];
while(j<=r) temp[k++]=s[j++];

for(i=l,j=0;i<=r;i++,j++)
s[i]=temp[j];
}

void mergeSort(Student s[],int l,int r){

if(l<r){

int m=(l+r)/2;

mergeSort(s,l,m);
mergeSort(s,m+1,r);
merge(s,l,m,r);
}
}

void display(Student s[],int n,int c){

printf("\n\n");
printf("                   STUDENT ACADEMIC RESULT SHEET\n");
printf("                   Ranked by Overall Performance\n");
printf("===========================================================================================\n");

printf("%-15s %-15s","Student ID","Name");

for(int i=0;i<c;i++)
printf("%-10s",courseNames[i]);

printf("%-8s %-8s %-8s %-8s\n","Avg","GPA","Grade","Result");

printf("===========================================================================================\n");

for(int i=0;i<n;i++){

printf("%-15s %-15s",s[i].id,s[i].name);

for(int j=0;j<c;j++)
printf("%-10.2f",s[i].marks[j]);

printf("%-8.2f %-8.2f %-8s %-8s\n",
s[i].avg,
s[i].gpa,
s[i].grade,
s[i].result);
}

printf("===========================================================================================\n");
}

void search(Student s[],int n,int c){

char id[20];

printf("Enter Student ID: ");
scanf("%s",id);

for(int i=0;i<n;i++){

if(strcmp(id,s[i].id)==0){

printf("\nStudent Found\n");
printf("Name: %s\n",s[i].name);

for(int j=0;j<c;j++)
printf("%s: %.2f\n",courseNames[j],s[i].marks[j]);

printf("Average: %.2f\n",s[i].avg);
printf("Grade: %s\n",s[i].grade);
printf("Result: %s\n",s[i].result);

return;
}
}

printf("Student Not Found\n");
}

void update(Student s[],int n,int c){

char id[20];

printf("Enter Student ID: ");
scanf("%s",id);

for(int i=0;i<n;i++){

if(strcmp(id,s[i].id)==0){

printf("Updating %s\n",s[i].name);

for(int j=0;j<c;j++){
printf("%s new marks: ",courseNames[j]);
scanf("%f",&s[i].marks[j]);
}

calculate(s,n,c);
mergeSort(s,0,n-1);

printf("Updated Successfully\n");
return;
}
}

printf("Student Not Found\n");
}

void statistics(Student s[],int n){

float max=s[0].avg;
float min=s[0].avg;
float sum=0;

for(int i=0;i<n;i++){

if(s[i].avg>max) max=s[i].avg;
if(s[i].avg<min) min=s[i].avg;

sum+=s[i].avg;
}

printf("\nClass Performance Summary\n");
printf("--------------------------\n");
printf("Highest Average : %.2f\n",max);
printf("Lowest Average  : %.2f\n",min);
printf("Class Average   : %.2f\n",sum/n);
}

void top(Student s[],int n){

int t;

printf("Top how many students: ");
scanf("%d",&t);

if(t>n) t=n;

printf("\nTop Performers\n");

for(int i=0;i<t;i++)
printf("%d. %s (%s) GPA: %.2f\n",
i+1,
s[i].name,
s[i].id,
s[i].gpa);
}

void save(Student s[],int n,int c){

FILE *fp=fopen("students.txt","w");

fprintf(fp,"%d %d %d\n",n,c,seq);

for(int i=0;i<c;i++)
fprintf(fp,"%s\n",courseNames[i]);

for(int i=0;i<n;i++){

fprintf(fp,"%s %s ",s[i].id,s[i].name);

for(int j=0;j<c;j++)
fprintf(fp,"%f ",s[i].marks[j]);

fprintf(fp,"\n");
}

fclose(fp);

printf("Data Saved Successfully\n");
}

int load(Student s[],int *n,int *c){

FILE *fp=fopen("students.txt","r");

if(fp==NULL){
printf("No saved file found\n");
return 0;
}

fscanf(fp,"%d %d %d",n,c,&seq);

for(int i=0;i<*c;i++)
fscanf(fp," %[^\n]",courseNames[i]);

for(int i=0;i<*n;i++){

fscanf(fp,"%s %s",s[i].id,s[i].name);

for(int j=0;j<*c;j++)
fscanf(fp,"%f",&s[i].marks[j]);
}

calculate(s,*n,*c);
mergeSort(s,0,*n-1);

fclose(fp);

printf("Data Loaded Successfully\n");
return 1;
}

void menu(){

printf("\n============= Student Marks Organizer =============\n");
printf("1. Input Students\n");
printf("2. Display Result Sheet\n");
printf("3. Search Student\n");
printf("4. Update Student\n");
printf("5. Top Performers\n");
printf("6. Class Statistics\n");
printf("7. Save Data\n");
printf("8. Load Data\n");
printf("9. Exit\n");
printf("Choose Option: ");
}

int main(){

Student s[MAX_STUDENTS];

int n=0,c=0,choice;

do{

menu();
scanf("%d",&choice);

switch(choice){

case 1:
printf("Number of Students: ");
scanf("%d",&n);

printf("Number of Courses: ");
scanf("%d",&c);

inputCourses(c);
inputStudents(s,n,c);
calculate(s,n,c);
mergeSort(s,0,n-1);
break;

case 2:
display(s,n,c);
break;

case 3:
search(s,n,c);
break;

case 4:
update(s,n,c);
break;

case 5:
top(s,n);
break;

case 6:
statistics(s,n);
break;

case 7:
save(s,n,c);
break;

case 8:
load(s,&n,&c);
break;

case 9:
printf("Exiting Program...\n");
break;

default:
printf("Invalid Choice\n");
}

}while(choice!=9);

return 0;
}
